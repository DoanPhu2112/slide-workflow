    "title-dns": {
      "regions": {
        "main": "\n            <h1>DNS Concept</h1>\n          "
      }
    },
    "dns-concepts": {
      "regions": {
        "main": "\n              <h2>DNS Basics</h2>\n              <ul class=\"plain-list\">\n                <li>User nhớ tên, network route theo IP</li>\n                <li>DNS map domain name sang địa chỉ</li>\n                <li>Namespace của DNS là một cây phân cấp</li>\n                <li>Mỗi node là một label, ghép lại thành FQDN</li>\n              </ul>\n            ",
        "media": "\n                  <div class=\"image-placeholder\">\n                    <span>Placeholder để bạn thêm hình domain namespace</span>\n                  </div>\n                "
      },
      "mediaWidth": 45,
      "mediaPosition": "right"
    },
    "dns-delegation": {
      "regions": {
        "main": "\n              <h2>Delegation và các loại DNS server</h2>\n              <ul class=\"plain-list\">\n                <li>Root server chỉ đường tới TLD</li>\n                <li>TLD server chỉ authority của zone tiếp theo</li>\n                <li>Authoritative server giữ record thật</li>\n                <li>`com` và `com.vn` đi theo nhánh authority khác nhau</li>\n              </ul>\n            ",
        "media": "\n                  <div class=\"image-placeholder\">\n                    <span>Placeholder để bạn thêm hình delegation và server types</span>\n                  </div>\n                "
      },
      "mediaWidth": 45,
      "mediaPosition": "right"
    },
    "dns-records": {
      "regions": {
        "main": "\n            <h2>CNAME và TXT</h2>\n            <div class=\"table-wrap table-wrap--medium\" data-table-wrap=\"\" style=\"--table-width: 74%;\">\n              <table>\n                <thead>\n                  <tr>\n                    <th>Record</th>\n                    <th>Dùng cho</th>\n                    <th>Ví dụ</th>\n                  </tr>\n                </thead>\n                <tbody>\n                  <tr>\n                    <td>CNAME</td>\n                    <td>Alias từ hostname này sang hostname khác</td>\n                    <td>`www...` → `doanvuquangphu...`</td>\n                  </tr>\n                  <tr>\n                    <td>TXT</td>\n                    <td>Verify ownership hoặc policy metadata</td>\n                    <td>`_vercel... TXT \"vc-domain-verify=...\"`</td>\n                  </tr>\n                </tbody>\n              </table>\n            </div>\n            <p class=\"caption\">Case điển hình: CNAME để trỏ custom domain, TXT để xác minh cùng owner.</p>\n          "
      },
      "tableWidth": 74
    },
    "dns-in-action": {
      "regions": {
        "main": "\n              <h2>DNS Resolution</h2>\n            ",
        "caption": "\n              DNS chỉ trả lời “đi đâu”, không tự giữ kết nối ứng dụng.\n            "
      }
    },
    "title-terms": {
      "regions": {
        "main": "\n            <h1>Thuật ngữ</h1>\n          "
      }
    },
    "terms-edge": {
      "regions": {
        "main": "\n            <h2>Edge Security Terms</h2>\n            <div class=\"glossary-grid\">\n              <article class=\"glossary-card\">\n                <h3>WAF</h3>\n                <p>Web Application Firewall.</p>\n                <p>Lọc request HTTP/HTTPS để chặn pattern tấn công như SQLi, XSS, path traversal.</p>\n                <p>Trong ARP: nằm ở F5 để chặn traffic xấu trước khi vào NGINX.</p>\n              </article>\n              <article class=\"glossary-card\">\n                <h3>SNI</h3>\n                <p>Server Name Indication trong TLS handshake.</p>\n                <p>Cho client nói trước hostname muốn truy cập dù payload HTTP chưa được giải mã.</p>\n                <p>Trong passthrough: proxy chỉ có thể đọc SNI để route TLS stream.</p>\n              </article>\n              <article class=\"glossary-card\">\n                <h3>JWT</h3>\n                <p>JSON Web Token.</p>\n                <p>Token mang claim định danh và quyền, thường được verify bằng signature.</p>\n                <p>Trong ARP: Ingress / Istio dùng JWT để chỉ cho request hợp lệ đi tiếp.</p>\n              </article>\n            </div>\n          "
      }
    },
    "terms-service": {
      "regions": {
        "main": "\n            <h2>Service-to-Service Terms</h2>\n            <div class=\"glossary-grid\">\n              <article class=\"glossary-card\">\n                <h3>mTLS</h3>\n                <p>Mutual TLS.</p>\n                <p>Cả client và server đều xuất trình certificate để xác thực hai chiều.</p>\n                <p>Trong service mesh: bảo vệ east-west traffic giữa các service.</p>\n              </article>\n              <article class=\"glossary-card\">\n                <h3>HMAC</h3>\n                <p>Hash-based Message Authentication Code.</p>\n                <p>Dùng shared secret để chứng minh message không bị sửa và đúng người gửi.</p>\n                <p>Trong backend integration: phù hợp cho callback, webhook, request signing.</p>\n              </article>\n              <article class=\"glossary-card\">\n                <h3>Vault</h3>\n                <p>Secret management system.</p>\n                <p>Lưu và cấp phát secret, token, certificate theo policy thay vì hardcode trong app.</p>\n                <p>Trong ARP: dùng để giữ credential và rotate secret an toàn hơn.</p>\n              </article>\n            </div>\n          "
      }
    },
    "terms-data": {
      "regions": {
        "main": "\n            <h2>Data Protection Terms</h2>\n            <div class=\"glossary-grid\">\n              <article class=\"glossary-card\">\n                <h3>SSE-KMS</h3>\n                <p>Server-Side Encryption with KMS-managed keys.</p>\n                <p>Dữ liệu được mã hóa ở storage side, còn key được quản lý bởi Key Management Service.</p>\n                <p>Phù hợp khi muốn kiểm soát quyền dùng key và audit key usage.</p>\n              </article>\n              <article class=\"glossary-card\">\n                <h3>Encryption at Rest</h3>\n                <p>Mã hóa dữ liệu khi đang được lưu trữ.</p>\n                <p>Khác với TLS là bảo vệ khi truyền, khái niệm này bảo vệ disk, DB, object storage.</p>\n                <p>Trong ARP: áp dụng cho backend storage và dữ liệu nhạy cảm.</p>\n              </article>\n              <article class=\"glossary-card\">\n                <h3>Basic Auth</h3>\n                <p>Cơ chế gửi username/password trong header Authorization.</p>\n                <p>Đơn giản nhưng phải đi kèm TLS vì credential chỉ được base64, không tự mã hóa.</p>\n                <p>Trong backend services: phù hợp cho một số hop nội bộ hoặc integration đơn giản.</p>\n              </article>\n            </div>\n          "
      }
    }
  },
  "diagrams": {
    "osi-sequence": "sequenceDiagram\nactor Client\nparticipant Eth as L2 Ethernet\nparticipant IP as L3 IP\nparticipant TCP as L4 TCP\nparticipant TLS as L6 TLS\nparticipant HTTP as L7 HTTP\nparticipant Proxy as Reverse Proxy\n\nClient->>Eth: Build frame in local network\nEth->>IP: Carry packet to next hop\nIP->>TCP: Route by source / destination IP\nTCP->>TLS: Open transport session on port 443\nTLS->>HTTP: Decrypt payload\nHTTP->>Proxy: Expose host, path, header, body\nNote over Eth,IP: L2-L3 chỉ thấy frame, MAC, IP, TTL, route info\nNote over TCP,TLS: L4-L6 thấy port, session, crypto metadata\nNote over HTTP,Proxy: Sau điểm giải mã mới inspect được request",
    "tls-sequence": "sequenceDiagram\nactor Client\nparticipant Server\n\nClient->>Server: ClientHello (TLS version, cipher list, SNI)\nServer-->>Client: ServerHello + selected cipher + Certificate\nClient->>Server: Verify cert chain + key exchange\nClient->>Server: Finished\nServer-->>Client: Finished\nClient->>Server: Encrypted HTTP request\nServer-->>Client: Encrypted HTTP response\nNote over Client,Server: Handshake để xác thực và sinh session key; data sau đó đi bằng symmetric crypto",
    "dns-sequence": "sequenceDiagram\nactor User\nparticipant OS as OS Stub Resolver\nparticipant Rec as Recursive Resolver\nparticipant Root as Root DNS\nparticipant TLD as TLD DNS\nparticipant Auth as Authoritative DNS\n\nUser->>OS: Enter slides.example.com\nOS->>Rec: Query A/AAAA slides.example.com\nRec->>Root: Where is .com?\nRoot-->>Rec: Ask .com TLD\nRec->>TLD: Where is example.com?\nTLD-->>Rec: Ask authoritative server\nRec->>Auth: Resolve slides.example.com\nAuth-->>Rec: Final record or CNAME chain\nRec-->>OS: Return IP and TTL for cache\nOS-->>User: Deliver resolved IP\nNote over User,OS: Client only starts TCP/TLS/HTTP after DNS returns destination"
  }
}
