    "ssl-passthrough": {
      "regions": {
        "main": "\n              <h2>SSL passthrough</h2>\n              <ul class=\"plain-list\">\n                <li>TLS đi <b>xuyên qua</b> proxy</li>\n                <li>Backend mới là nơi giải mã</li>\n                <li>Proxy nhẹ hơn</li>\n                <li>Không inspect được HTTP</li>\n              </ul>\n            ",
        "media": "\n                  <img class=\"media-image\" src=\"./assets/ssl-passthrough-1781167598829.png\" alt=\"\">\n                "
      },
      "mediaWidth": 100,
      "mediaPosition": "below"
    },
    "ssl-bridge": {
      "regions": {
        "main": "\n              <h2>SSL bridge</h2>\n              <ul class=\"plain-list\">\n                <li>Proxy giải mã để inspect</li>\n                <li>Proxy tạo TLS session mới tới backend</li>\n                <li>Có thể inspect trong quá trình xử lý trong Proxy</li>\n              </ul>\n            ",
        "media": "\n                  <img class=\"media-image\" src=\"./assets/ssl-bridge-1781167766634.png\" alt=\"\">\n                "
