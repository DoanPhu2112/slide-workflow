    },
    "ssl-terminate": {
      "regions": {
        "main": "\n              <h2>SSL terminate</h2>\n              <ul class=\"plain-list\">\n                <li>Proxy giải mã ở edge</li>\n                <li>Edge route dựa trên HTTP request thật</li>\n                <li>L7 control mạnh nhất</li>\n                <li>Đơn giản hơn bridge</li>\n              </ul>\n            ",
        "media": "\n                  <img class=\"media-image\" src=\"./assets/ssl-terminate-1781148672557.png\" alt=\"\">\n                "
      },
      "mediaWidth": 100,
