    "current-ssl": {
      "regions": {
        "main": "\n              <h2>Current SSL</h2>\n              <ul class=\"plain-list\">\n                <li>Ưu điểm: inspect host, path, header và áp policy Layer 7</li>\n                <li>Ưu điểm: offload TLS cho backend</li>\n                <li>Đổi lại: nếu không re-encrypt, trust chuyển vào mạng nội bộ</li>\n                <li>Inspect chỉ xuất hiện sau khi payload được giải mã</li>\n              </ul>\n            ",
        "media": "\n                  <img class=\"media-image\" src=\"./assets/current-ssl-1781149150535.png\" alt=\"\">\n                ",
