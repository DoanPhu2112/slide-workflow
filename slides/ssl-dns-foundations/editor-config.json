    },
    "ssl-tradeoffs": {
      "regions": {
        "main": "\n            <h2>SSL Tradeoffs</h2>\n            <div class=\"table-wrap\" data-table-wrap=\"\" style=\"--table-width: 82%;\">\n              <table>\n                <thead>\n                  <tr>\n                    <th>Tiêu chí</th>\n                    <th>Passthrough</th>\n                    <th>Bridge</th>\n                    <th>Terminate</th>\n                  </tr>\n                </thead>\n                <tbody>\n                  <tr>\n                    <td>Request inspect</td>\n                    <td>&nbsp;Không</td>\n                    <td>Có</td>\n                    <td>Có</td>\n                  </tr>\n                  <tr>\n                    <td>SSL overhead ở proxy</td>\n                    <td>Thấp</td>\n                    <td>Cao nhất</td>\n                    <td>Trung bình</td>\n                  </tr>\n                  <tr>\n                    <td>SSL overhead ở backend</td>\n                    <td>Cao</td>\n                    <td>Cao</td>\n                    <td>Thấp hoặc không có</td>\n                  </tr>\n                  <tr>\n                    <td>Rủi ro plaintext nội bộ</td>\n                    <td>Thấp</td>\n                    <td>Thấp</td>\n                    <td>Cao hơn nếu không mã hóa lại</td>\n                  </tr>\n                  <tr>\n                    <td>WAF / auth / rate limit theo HTTP</td>\n                    <td>Khó</td>\n                    <td>Dễ</td>\n                    <td>Dễ</td>\n                  </tr>\n                </tbody>\n              </table>\n            </div>\n            <p class=\"caption\">Bridge và terminate inspect mạnh hơn. Passthrough và bridge giữ internal hop kín hơn.</p>\n          "
      },
      "tableWidth": 82
    },
    "title-osi": {
      "regions": {
        "main": "\n            <h1>OSI model</h1>\n          "
      }
    },
    "osi-sequence-slide": {
      "regions": {
        "main": "\n              <h2>OSI Layers</h2>\n            ",
        "layer-map": "\n              <table>\n                <thead>\n                  <tr>\n                    <th>Layer</th>\n                    <th>Ánh xạ thực tế</th>\n                    <th>Inspect bằng gì</th>\n                    <th>Ví dụ nhìn thấy gì</th>\n                  </tr>\n                </thead>\n                <tbody>\n                  <tr>\n                    <td>L1 Physical</td>\n                    <td>Signal / wire / radio</td>\n                    <td>\n                      <div class=\"cell-stack\">\n                        <div><code>ethtool</code></div>\n                        <div>NIC stats</div>\n                        <div>Link LEDs</div>\n                      </div>\n                    </td>\n                    <td>\n                      <div class=\"cell-stack\">\n                        <div>Link up/down</div>\n                        <div>Speed: <code>1Gbps</code></div>\n                        <div>Duplex: <code>full</code></div>\n                        <div>Signal level</div>\n                      </div>\n                    </td>\n                  </tr>\n                  <tr>\n                    <td>L2 Data Link</td>\n                    <td>Ethernet / MAC / frame</td>\n                    <td>\n                      <div class=\"cell-stack\">\n                        <div><code>tcpdump -e</code></div>\n                        <div><code>ip link</code></div>\n                        <div><code>bridge vlan show</code></div>\n                      </div>\n                    </td>\n                    <td>\n                      <div class=\"cell-stack\">\n                        <div>MAC: <code>00:1a:2b:3c:4d:5e</code></div>\n                        <div>VLAN: <code>20</code></div>\n                        <div>EtherType: <code>0x0800</code></div>\n                      </div>\n                    </td>\n                  </tr>\n                  <tr>\n                    <td>L3 Network</td>\n                    <td>IP packet</td>\n                    <td>\n                      <div class=\"cell-stack\">\n                        <div><code>ip route</code></div>\n                        <div><code>traceroute</code></div>\n                        <div><code>tcpdump -n</code></div>\n                      </div>\n                    </td>\n                    <td>\n                      <div class=\"cell-stack\">\n                        <div>Src IP: <code>10.10.10.10</code></div>\n                        <div>Dst IP: <code>172.16.1.25</code></div>\n                        <div>TTL: <code>64</code></div>\n                      </div>\n                    </td>\n                  </tr>\n                  <tr>\n                    <td>L4 Transport</td>\n                    <td>TCP / UDP</td>\n                    <td>\n                      <div class=\"cell-stack\">\n                        <div><code>ss -tnp</code></div>\n                        <div><code>netstat -an</code></div>\n                        <div><code>tcpdump tcp port 443</code></div>\n                      </div>\n                    </td>\n                    <td>\n                      <div class=\"cell-stack\">\n                        <div>Src port: <code>51544</code></div>\n                        <div>Dst port: <code>443</code></div>\n                        <div>Seq: <code>12345</code></div>\n                        <div>State: <code>ESTABLISHED</code></div>\n                      </div>\n                    </td>\n                  </tr>\n                  <tr>\n                    <td>L5 Session</td>\n                    <td>Logical session</td>\n                    <td>\n                      <div class=\"cell-stack\">\n                        <div><code>openssl s_client -reconnect</code></div>\n                        <div>Session logs</div>\n                      </div>\n                    </td>\n                    <td>\n                      <div class=\"cell-stack\">\n                        <div>TLS session reuse</div>\n                        <div>Session ID</div>\n                        <div>Keep-alive</div>\n                        <div>Reconnect context</div>\n                      </div>\n                    </td>\n                  </tr>\n                  <tr>\n                    <td>L6 Presentation</td>\n                    <td>TLS / encoding / format</td>\n                    <td>\n                      <div class=\"cell-stack\">\n                        <div><code>openssl s_client</code></div>\n                        <div><code>tshark -d tcp.port==443,tls</code></div>\n                      </div>\n                    </td>\n                    <td>\n                      <div class=\"cell-stack\">\n                        <div>TLS: <code>1.3</code></div>\n                        <div>Cipher: <code>TLS_AES_128_GCM_SHA256</code></div>\n                        <div>Cert CN</div>\n                        <div>SNI: <code>api.example.com</code></div>\n                      </div>\n                    </td>\n                  </tr>\n                  <tr>\n                    <td>L7 Application</td>\n                    <td>HTTP / DNS / SMTP</td>\n                    <td>\n                      <div class=\"cell-stack\">\n                        <div><code>curl -v</code></div>\n                        <div><code>ngrep</code></div>\n                        <div>App logs</div>\n                        <div>DevTools</div>\n                      </div>\n                    </td>\n                    <td>\n                      <div class=\"cell-stack\">\n                        <div><code>GET /orders</code></div>\n                        <div><code>Host: api.example.com</code></div>\n                        <div><code>Authorization: Bearer ...</code></div>\n                        <div><code>200 OK</code></div>\n                      </div>\n                    </td>\n                  </tr>\n                </tbody>\n              </table>\n            ",
        "proxy-cases": "\n              <article class=\"proxy-case-card\">\n                <h3>Passthrough</h3>\n                <div class=\"proxy-case-sequence\">\n                  <div class=\"proxy-seq-node\">Client TLS</div>\n                  <div class=\"proxy-seq-arrow\"></div>\n                  <div class=\"proxy-shell\">\n                    <div class=\"proxy-shell__title\">Proxy</div>\n                    <div class=\"proxy-shell__steps\">\n                      <div class=\"proxy-seq-node proxy-seq-node--proxy\">Read SNI</div>\n                      <div class=\"proxy-seq-arrow proxy-seq-arrow--inner\"></div>\n                      <div class=\"proxy-seq-node proxy-seq-node--proxy\">No decrypt</div>\n                      <div class=\"proxy-seq-arrow proxy-seq-arrow--inner\"></div>\n                      <div class=\"proxy-seq-node proxy-seq-node--proxy\">Forward TLS</div>\n                    </div>\n                  </div>\n                  <div class=\"proxy-seq-arrow\"></div>\n                  <div class=\"proxy-seq-node\">Backend TLS</div>\n                </div>\n              </article>\n\n              <article class=\"proxy-case-card\">\n                <h3>Bridge</h3>\n                <div class=\"proxy-case-sequence\">\n                  <div class=\"proxy-seq-node\">Client TLS</div>\n                  <div class=\"proxy-seq-arrow\"></div>\n                  <div class=\"proxy-shell\">\n                    <div class=\"proxy-shell__title\">Proxy</div>\n                    <div class=\"proxy-shell__steps\">\n                      <div class=\"proxy-seq-node proxy-seq-node--proxy\">Terminate TLS</div>\n                      <div class=\"proxy-seq-arrow proxy-seq-arrow--inner\"></div>\n                      <div class=\"proxy-seq-node proxy-seq-node--proxy\">Inspect HTTP</div>\n                      <div class=\"proxy-seq-arrow proxy-seq-arrow--inner\"></div>\n                      <div class=\"proxy-seq-node proxy-seq-node--proxy\">Re-encrypt</div>\n                    </div>\n                  </div>\n                  <div class=\"proxy-seq-arrow\"></div>\n                  <div class=\"proxy-seq-node\">Backend TLS</div>\n                </div>\n              </article>\n\n              <article class=\"proxy-case-card\">\n                <h3>Terminate</h3>\n                <div class=\"proxy-case-sequence\">\n                  <div class=\"proxy-seq-node\">Client TLS</div>\n                  <div class=\"proxy-seq-arrow\"></div>\n                  <div class=\"proxy-shell\">\n                    <div class=\"proxy-shell__title\">Proxy</div>\n                    <div class=\"proxy-shell__steps\">\n                      <div class=\"proxy-seq-node proxy-seq-node--proxy\">Terminate TLS</div>\n                      <div class=\"proxy-seq-arrow proxy-seq-arrow--inner\"></div>\n                      <div class=\"proxy-seq-node proxy-seq-node--proxy\">Inspect HTTP</div>\n                      <div class=\"proxy-seq-arrow proxy-seq-arrow--inner\"></div>\n                      <div class=\"proxy-seq-node proxy-seq-node--proxy\">Forward HTTP</div>\n                    </div>\n                  </div>\n                  <div class=\"proxy-seq-arrow\"></div>\n                  <div class=\"proxy-seq-node\">Backend HTTP</div>\n                </div>\n              </article>\n            ",
        "notes": "\n              <li>L2 và L3 chỉ lo chuyển gói tin, chưa hiểu ứng dụng</li>\n              <li>L4 thấy port và session transport, vẫn chưa thấy URL hay header</li>\n              <li>L7 chỉ lộ ra sau điểm giải mã TLS, nên reverse proxy mới inspect được HTTP</li>\n            "
      }
    },
    "title-tls": {
      "regions": {
        "main": "\n            <h1>Cách SSL hoạt động</h1>\n          "
      }
    },
    "tls-sequence-slide": {
      "regions": {
        "main": "\n              <h2>TLS Handshake</h2>\n              <div class=\"tls-summary-grid\">\n                <article class=\"tls-card\">\n                  <h3>Handshake dùng để làm gì</h3>\n                  <ol class=\"number-list tls-list\">\n                    <li>Trao đổi message để hai bên ACK và mở đầu phiên.</li>\n                    <li>Xác thực server bằng certificate; có thể xác thực hai chiều nếu dùng mTLS.</li>\n                    <li>Đồng thuận version TLS, cipher suite và tham số crypto sẽ dùng.</li>\n                    <li>Sinh ra session key để bảo vệ application data phía sau.</li>\n                  </ol>\n                </article>\n                <article class=\"tls-card\">\n                  <h3>Sau handshake có gì</h3>\n                  <ul class=\"plain-list tls-list\">\n                    <li>Client biết đang nói chuyện với ai.</li>\n                    <li>Hai bên có chung session key nhưng không truyền plaintext key trên wire.</li>\n                    <li>HTTP data chỉ bắt đầu được mã hóa sau khi handshake hoàn tất.</li>\n                  </ul>\n                </article>\n              </div>\n            ",
        "caption": "\n              Handshake diễn ra trước. Chỉ sau khi có session key thì request và response HTTP mới đi dưới dạng encrypted application data.\n            "
      }
    },
    "tls-trust-slide": {
      "regions": {
        "main": "\n              <h2>Certificate &amp; Trust</h2>\n            ",
        "issuance": "\n                <h3>Proxy đăng ký certificate với CA</h3>\n                <ol class=\"number-list tls-list\">\n                  <li>Tạo private key.</li>\n                  <li>Tạo CSR.</li>\n                  <li>Gửi CSR cho CA.</li>\n                  <li>CA xác minh domain hoặc tổ chức.</li>\n                  <li>CA cấp certificate.</li>\n                  <li>Cài certificate và private key lên F5, NGINX hoặc Ingress.</li>\n                </ol>\n              ",
        "trust": "\n                <h3>Client tin certificate dựa vào đâu</h3>\n                <ul class=\"plain-list tls-list\">\n                  <li>Browser, OS hoặc runtime sẽ có sẵn danh sách root CA đáng tin.</li>\n                  <li>Nếu certificate chain nối được về một root CA trong trust store thì certificate được chấp nhận.</li>\n                  <li>Private hoặc internal root CA chỉ được tin khi bạn chủ động import vào trust store.</li>\n                </ul>\n              ",
        "store-map": "\n              <table>\n                <thead>\n                  <tr>\n                    <th>Nền tảng / trình duyệt</th>\n                    <th>Root CA trust store</th>\n                  </tr>\n                </thead>\n                <tbody>\n                  <tr>\n                    <td>Windows / Edge / Chrome trên Windows</td>\n                    <td>Microsoft Trusted Root Program</td>\n                  </tr>\n                  <tr>\n                    <td>macOS / iOS / Safari</td>\n                    <td>Apple Trust Store</td>\n                  </tr>\n                  <tr>\n                    <td>Firefox</td>\n                    <td>Mozilla Root Store / NSS</td>\n                  </tr>\n                  <tr>\n                    <td>Chrome</td>\n                    <td>Chrome Root Store</td>\n                  </tr>\n                  <tr>\n                    <td>Java app</td>\n                    <td>Java <code>cacerts</code> truststore</td>\n                  </tr>\n                  <tr>\n                    <td>Linux</td>\n                    <td>CA bundle của distro, thường dựa nhiều vào Mozilla CA bundle</td>\n                  </tr>\n                  <tr>\n                    <td><b><i>Nội bộ doanh nghiệp</i></b></td>\n                    <td><b><i>Private / internal root CA</i></b></td>\n                  </tr>\n                </tbody>\n              </table>\n            ",
        "example": "\n              <p class=\"caption\">Ví dụ trên Fedora: <code>trust list</code></p>\n              <pre><code>pkcs11:id=%98%39%CD%BE%D8%B2%8C%F7%B2%AB%E1%AD%24%AF%7B%7C%A1%DB%1F%CF;type=cert\n    type: certificate\n    label: vTrus ECC Root CA\n    trust: anchor\n    category: authority\n\npkcs11:id=%54%62%70%63%F1%75%84%43%58%8E%D1%16%20%B1%C6%AC%1A%BC%F6%89;type=cert\n    type: certificate\n    label: vTrus Root CA\n    trust: anchor\n    category: authority</code></pre>\n            "
      },
      "tableWidth": 96
    },
    "title-crypto": {
      "regions": {
        "main": "\n            <h1>Symmetric vs asymmetric key</h1>\n          "
      }
